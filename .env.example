# Database
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Authentication
AUTH_SECRET="your-auth-secret-here"
NEXT_PUBLIC_GOOGLE_CLIENT_ID_DEV="your-google-client-id-here"
GOOGLE_CLIENT_SECRET_DEV="your-google-client-secret-here"

# API Keys
OPENROUTER_API_KEY="your-openrouter-api-key-here"
REQUESTY_API_KEY="your-requesty-api-key-here"

# App Configuration
NEXT_PUBLIC_APP_URL="https://your-app-url.com"
NEXT_PUBLIC_APP_TITLE="Your App Title"
ALLOW_ANON_OWN_KEYS=false

# Polar Payments
POLAR_ACCESS_TOKEN="your-polar-access-token-here"
POLAR_WEBHOOK_SECRET="your-polar-webhook-secret-here"
SUCCESS_URL="https://your-app-url.com/checkout/success?checkout_id={CHECKOUT_ID}"
POLAR_PRODUCT_ID="your-polar-product-id-here"
POLAR_SERVER_ENV="production"

# Title Generation Models
TITLE_GENERATION_MODEL_ID="openrouter/qwen/qwen-turbo"
OPENROUTER_TITLE_MODEL="openrouter/qwen/qwen-turbo"
REQUESTY_TITLE_MODEL="requesty/alibaba/qwen-turbo"
OPENAI_TITLE_MODEL="gpt-5-nano"
ANTHROPIC_TITLE_MODEL="claude-3-7-sonnet"
GROQ_TITLE_MODEL="qwen-qwq"
XAI_TITLE_MODEL="grok-3-mini"

# Vercel Flags configuration
FLAGS_SECRET="your-flags-secret-here"

# Statsig (Vercel Experimentation Provider)
NEXT_PUBLIC_STATSIG_CLIENT_KEY="your-statsig-client-key-here"
STATSIG_SERVER_SECRET="your-statsig-server-secret-here"