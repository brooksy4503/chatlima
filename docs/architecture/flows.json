    { "id": "svc-model", "label": "chatModelValidationService", "path": "lib/services/chatModelValidationService.ts", "group": "lib-services" },
    { "id": "svc-message", "label": "chatMessageProcessingService", "path": "lib/services/chatMessageProcessingService.ts", "group": "lib-services" },
