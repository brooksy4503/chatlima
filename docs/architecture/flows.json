  "flows": [
    {
      "id": "send-chat-message",
      "label": "Send chat message",
      "category": "Chat",
      "description": "User submits a prompt; server uses modular lib/chat (chatRequest parse → chatPreflight → buildChatStreamPlan → streamText + finalizer) for auth/credits/model/access/websearch/imagegen/MCP/project context, streams from AI with tools, persists UIMessage parts (incl. generated images), tracks usage.",
      "steps": [
        {
          "from": "chat",
          "to": "textarea",
          "label": "User input",
          "payload": "text, attachments[], selected model from model-context, webSearch toggle from WebSearchProvider"
        },
        {
          "from": "chat",
          "to": "mcp-context",
          "label": "Read MCP config",
          "payload": "enabled MCP servers from localStorage via browser-storage"
        },
        {
          "from": "chat",
          "to": "preset-context",
          "label": "Read preset",
          "payload": "system prompt, temperature, maxTokens, optional webSearch override"
        },
        {
          "from": "chat",
          "to": "chat-project-selector",
          "label": "Linked project",
          "payload": "chatId may be linked to a project via chat_projects (context injected server-side)"
        },
        {
          "from": "chat",
          "to": "api-chat",
          "label": "useChat → POST",
          "payload": "{ id, messages: UIMessage[], selectedModel, apiKeys?, mcpServers[], webSearch: { enabled, contextSize }, presetId?, attachments[], imageGeneration? }"
        },
        {
          "from": "api-chat",
          "to": "chat-request",
          "label": "Parse request body",
          "payload": "parseChatRequestBody → ChatRequestBody (typed messages, model, attachments, mcp, webSearch, imageGen, systemInstruction overrides, presetId)"
        },
        {
          "from": "chat-request",
          "to": "chat-preflight",
          "label": "Run preflight checks",
          "payload": "orchestrates auth, access, credits, model, websearch, image gen, daily usage; returns preflight context or error"
        },
        {
          "from": "chat-preflight",
          "to": "svc-auth",
          "label": "Authenticate",
          "payload": "session cookie → AuthenticatedUser { id, isAnonymous, email }"
        },
        {
          "from": "chat-preflight",
          "to": "access-policy",
          "label": "Feature flags",
          "payload": "OPENROUTER_AGENTIC_WEB_TOOLS_ENABLED, NATIVE_WEB_FETCH_ENABLED, BILLING_ENFORCED"
        },
        {
          "from": "chat-preflight",
          "to": "svc-access",
          "label": "Access gate",
          "payload": "canUserChat, BYOK check when billing enforced"
        },
        {
          "from": "chat-preflight",
          "to": "svc-credit",
          "label": "Validate credits / limits",
          "payload": "userId, modelId, webSearch flag → CreditValidationResult; calls polar-lib + token-counter"
        },
        {
          "from": "svc-credit",
          "to": "polar-lib",
          "label": "Polar balance check",
          "payload": "externalCustomerId → remaining credits, subscription type"
        },
        {
          "from": "chat-preflight",
          "to": "svc-model",
          "label": "Validate model",
          "payload": "modelId, user tier → ModelValidationResult (credit tier / BYOK)"
        },
        {
          "from": "chat-preflight",
          "to": "svc-message",
          "label": "Process messages",
          "payload": "UIMessage[] → normalized messages, image parts, read_file tool content (delegated from preflight)"
        },
        {
          "from": "chat-preflight",
          "to": "svc-websearch",
          "label": "Validate web search",
          "payload": "WebSearchContext → WebSearchResult; signed-in + ≥5 credits or BYOK; model supportsWebSearch"
        },
        {
          "from": "chat-preflight",
          "to": "svc-image-gen",
          "label": "Validate image gen",
          "payload": "imageGeneration flag + model support → resolved image model, tool injection decision"
        },
        {
          "from": "chat-preflight",
          "to": "svc-daily-usage",
          "label": "Daily usage check",
          "payload": "anonymous / free tier message limits per day"
        },
        {
          "from": "api-chat",
          "to": "svc-project-context",
          "label": "Project context",
          "payload": "chatId + userId → instructions + file list appended to system prompt"
        },
        {
          "from": "api-chat",
          "to": "svc-mcp",
          "label": "Connect MCP tools",
          "payload": "MCPServerConfig[] → MCP Client tools merged into streamText"
        },
        {
          "from": "svc-mcp",
          "to": "ext-mcp-servers",
          "label": "MCP protocol",
          "payload": "SSE/streamable-http; tools/list, tools/call; OAuth via mcpOAuthProvider"
        },
        {
          "from": "api-chat",
          "to": "build-chat-stream-plan",
          "label": "Build stream plan",
          "payload": "assembles model instance, tools, system instr, formatted messages, web search config, image force, effective params; delegates to submodules"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "svc-or-websearch-setup",
          "label": "OpenRouter web search setup",
          "payload": "Agentic path: openrouter:web_search + web_fetch server tools; legacy path: :online suffix when flag off"
        },
        {
          "from": "svc-or-websearch-setup",
          "to": "openrouter-provider",
          "label": "Server tools",
          "payload": "ChatWebSearchService.buildOpenRouterServerTools(contextSize, maxTotalResults)"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "svc-webfetch",
          "label": "Native web_fetch tool",
          "payload": "SSR-safe URL fetch (DNS/IP validation, HTML→markdown) when NATIVE_WEB_FETCH_ENABLED"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "ai-providers",
          "label": "Resolve model",
          "payload": "modelId + user apiKeys → LanguageModel; tag-based reasoning wrap when applicable (via getLanguageModelWithKeys)"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "chat-tools",
          "label": "Build base tools",
          "payload": "buildBaseChatTools + buildWebFetchPolicy; merges MCP, web search server tools, image_generation tool"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "system-instruction",
          "label": "Build system prompt",
          "payload": "buildDefaultSystemInstruction + project context + preset + image gen guardrails"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "prepare-messages",
          "label": "Prepare messages",
          "payload": "prepareMessagesForModel: strip client-only parts, attach file contents, apply reasoning extraction"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "google-model-tools",
          "label": "Sanitize tool schemas",
          "payload": "cleanToolsForGoogleModels strips $schema from tool inputs for Gemini/Vertex"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "parameter-validation",
          "label": "Apply model defaults",
          "payload": "getModelDefaults for temperature / maxTokens if not overridden"
        },
        {
          "from": "build-chat-stream-plan",
          "to": "reasoning-models",
          "label": "Reasoning model handling",
          "payload": "modelShouldDisableLogprobs, wrapWithTagBasedReasoning for o1-style etc."
        },
        {
          "from": "ai-providers",
          "to": "vercel-ai-sdk",
          "label": "streamText",
          "payload": "{ model, messages, tools, system, stopWhen: stepCountIs(20), abortSignal, prepareStep for forced image gen }"
        },
        {
          "from": "vercel-ai-sdk",
          "to": "ext-openrouter",
          "label": "Provider call",
          "payload": "OpenRouter or Requesty API key (app or BYOK); agentic web_search invocations billed per count"
        },
        {
          "from": "api-chat",
          "to": "chat-stop-registry",
          "label": "Register abort",
          "payload": "AbortController keyed userId:chatId for { action: 'stop' } requests"
        },
        {
          "from": "api-chat",
          "to": "chat-stream-consumption",
          "label": "Background consume",
          "payload": "result.consumeStream() on client disconnect so persistence completes"
        },
        {
          "from": "api-chat",
          "to": "chat-stream-finalizer",
          "label": "Create stream finalizer",
          "payload": "createChatStreamFinalizer with plan, preflight context, title promise; handles onFinish, timing, persistence, credits, tokens"
        },
        {
          "from": "chat-stream-finalizer",
          "to": "chat-message-persistence",
          "label": "Build assistant message",
          "payload": "buildAssistantMessageForPersistence: UIMessage parts, reasoning, tool invocations, citations; persistClientMessagesAtRequestStart"
        },
        {
          "from": "chat-message-persistence",
          "to": "message-utils",
          "label": "Web search parts",
          "payload": "hasWebSearchToolPart, injectSyntheticWebSearchToolPart for UI consistency; extract image urls"
        },
        {
          "from": "chat-stream-finalizer",
          "to": "stream-token-usage",
          "label": "Compute usage",
          "payload": "computeStreamTokenUsage, computeTokensPerSecond, estimateTimeToFirstTokenMs"
        },
        {
          "from": "chat-stream-finalizer",
          "to": "svc-token",
          "label": "Track usage",
          "payload": "token usage + web search invocation count → CostCalculationService, Polar usage events"
        },
        {
          "from": "svc-token",
          "to": "ext-polar",
          "label": "Bill usage",
          "payload": "metered usage event (when applicable)"
        },
        {
          "from": "api-chat",
          "to": "svc-db",
          "label": "Persist chat",
          "payload": "chat id, messages[] → chats + messages tables (via finalizer + ChatDatabaseService)"
        },
        {
          "from": "svc-db",
          "to": "db-index",
          "label": "Drizzle ORM",
          "payload": "insert/update via schema types"
        },
        {
          "from": "svc-db",
          "to": "db-index",
          "label": "Drizzle ORM",
